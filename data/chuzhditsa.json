{
  "name": "chuzhditsa",
  "version": "2.1",
  "encoding": {
    "normalization": "NFC",
    "policy": "precomposed codepoint when Unicode has one; combining mark otherwise",
    "canonical_sequences": {"нь": "U+043D U+044C", "ль": "U+043B U+044C", "ѩ": "U+044C U+0467 (precomposed U+0469 accepted)", "ѭ": "U+044C U+046B (precomposed U+046D accepted)"},
    "apostrophe": "U+2019",
    "palochka": "U+04C0",
    "warnings": ["NFKC decomposes U+02B0/U+02B1 to Latin h/ɦ — never NFKC-fold", "regex \\w splits at combining marks; tokenize with [\\p{L}\\p{M}’]+"]
  },
  "modifiers": [
    {"mark": "U+0306", "name": "breve", "feature": "glide", "examples": ["и→й /j/", "у→ў /w/"]},
    {"mark": "U+0322", "name": "hook below", "feature": "place off native grid", "examples": ["к→қ /q/", "х→ҳ /ħ/", "н→ң /ŋ/", "с→ҫ /θ/", "з→ҙ /ð/", "т→т̢ /ʈ/", "д→д̢ /ɖ/", "р→р̢ /ɽ/"]},
    {"mark": "U+0335", "name": "crossbar", "feature": "lenition", "examples": ["г→ғ /ɣ/"]},
    {"mark": "U+0308", "name": "double dot", "feature": "vowel fronting", "examples": ["а→ӓ /æ/", "о→ӧ /ø œ/", "у→ӱ /y ʏ/"]},
    {"mark": "U+0328", "name": "yus tail", "feature": "nasalization", "examples": ["о→ѫ /ɔ̃ õ/", "е→ѧ /ɛ̃/", "а̨ /ɑ̃ ɐ̃/", "ӧ̨ /œ̃/"]},
    {"mark": "U+02B0", "name": "raised h", "feature": "aspiration"},
    {"mark": "U+02B1", "name": "raised hooked h", "feature": "breathy voice"},
    {"mark": "U+0304", "name": "macron", "feature": "vowel length"},
    {"mark": "U+04C0", "name": "palochka", "feature": "laryngeal-pharyngeal action", "examples": ["тӀ кӀ цӀ ejectives", "bare Ӏ = /ʕ/"]},
    {"mark": "U+044C", "name": "soft sign", "feature": "palatalization", "examples": ["нь /ɲ/", "ль /ʎ/", "хь /ç/", "сь /ɕ/"]}
  ],
  "consonants": [
    {"ipa": "p", "graphemes": "п"}, {"ipa": "b", "graphemes": "б"},
    {"ipa": "t t̪", "graphemes": "т"}, {"ipa": "d d̪", "graphemes": "д"},
    {"ipa": "ʈ", "graphemes": "т̢", "codepoints": ["U+0442", "U+0322"]},
    {"ipa": "ɖ", "graphemes": "д̢", "codepoints": ["U+0434", "U+0322"]},
    {"ipa": "k", "graphemes": "к"}, {"ipa": "g", "graphemes": "г"},
    {"ipa": "q ɢ", "graphemes": "қ", "codepoints": ["U+049B"], "merges": ["q", "ɢ"]},
    {"ipa": "ʔ", "graphemes": "’", "codepoints": ["U+2019"], "note": "dropped outside Arabic contexts"},
    {"ipa": "c", "graphemes": "ть|кь", "context": "source-base rule: dental base if source writes it as dental (Slovak ť), velar base otherwise (Albanian q)"},
    {"ipa": "ɟ", "graphemes": "дь|гь", "context": "source-base rule, as for /c/"},
    {"ipa": "pʰ tʰ kʰ tʃʰ", "graphemes": "пʰ тʰ кʰ чʰ", "codepoints_suffix": ["U+02B0"]},
    {"ipa": "bʱ dʱ ɡʱ dʒʱ", "graphemes": "бʱ дʱ гʱ џʱ", "codepoints_suffix": ["U+02B1"]},
    {"ipa": "m", "graphemes": "м"}, {"ipa": "n", "graphemes": "н"},
    {"ipa": "ɳ", "graphemes": "н̢", "codepoints": ["U+043D", "U+0322"]},
    {"ipa": "ɲ", "graphemes": "нь|н+я/ю/ьо", "context": "н+я/ю/ьо before vowels (Кеня), нь elsewhere"},
    {"ipa": "ŋ", "graphemes": "ң", "codepoints": ["U+04A3"]},
    {"ipa": "f ɸ", "graphemes": "ф", "merges": ["ɸ"]}, {"ipa": "v β", "graphemes": "в", "merges": ["β"]},
    {"ipa": "θ", "graphemes": "ҫ", "codepoints": ["U+04AB"]},
    {"ipa": "ð", "graphemes": "ҙ", "codepoints": ["U+0499"]},
    {"ipa": "s", "graphemes": "с"}, {"ipa": "z", "graphemes": "з"},
    {"ipa": "ʃ ʂ", "graphemes": "ш", "merges": ["ʂ"]}, {"ipa": "ʒ ʐ", "graphemes": "ж", "merges": ["ʐ"]},
    {"ipa": "ɕ", "graphemes": "сь|ш", "context": "сь under contrast (Mandarin, Polish); ш by entrenchment (суши); Russian ɕː → шч"},
    {"ipa": "ç", "graphemes": "хь"},
    {"ipa": "x χ", "graphemes": "х", "merges": ["χ"]},
    {"ipa": "ɣ", "graphemes": "ғ", "codepoints": ["U+0493"]},
    {"ipa": "ħ", "graphemes": "ҳ", "codepoints": ["U+04B3"]},
    {"ipa": "ʕ", "graphemes": "Ӏ", "codepoints": ["U+04C0"]},
    {"ipa": "h ɦ", "graphemes": "һ", "codepoints": ["U+04BB"], "merges": ["ɦ"]},
    {"ipa": "ts", "graphemes": "ц"}, {"ipa": "dz", "graphemes": "ѕ", "codepoints": ["U+0455"]},
    {"ipa": "tʃ tʂ tɕ", "graphemes": "ч", "merges": ["tʂ", "tɕ"]},
    {"ipa": "dʒ dʐ dʑ", "graphemes": "џ", "codepoints": ["U+045F"], "merges": ["dʐ", "dʑ"]},
    {"ipa": "w", "graphemes": "ў|у", "codepoints": ["U+045E"], "context": "ў in onsets; у as offglide (Са̨у)"},
    {"ipa": "j", "graphemes": "й"},
    {"ipa": "l ɫ", "graphemes": "л", "merges": ["ɫ"]}, {"ipa": "ʎ", "graphemes": "ль"},
    {"ipa": "r ɾ ɹ ʀ ʁ", "graphemes": "р", "merges": ["ɾ", "ɹ", "ʀ", "ʁ"], "note": "English input referenced to rhotic GA"},
    {"ipa": "ɽ", "graphemes": "р̢", "codepoints": ["U+0440", "U+0322"]},
    {"ipa": "tʼ kʼ tsʼ", "graphemes": "тӀ кӀ цӀ", "note": "font fuses with raised palochka"},
    {"ipa": "ɓ ɗ", "graphemes": "б д", "merges": ["ɓ", "ɗ"]}
  ],
  "vowels": [
    {"ipa": "i ɪ", "graphemes": "и"}, {"ipa": "u ʊ", "graphemes": "у"},
    {"ipa": "e ɛ", "graphemes": "е"}, {"ipa": "o ɔ", "graphemes": "о"},
    {"ipa": "æ", "graphemes": "ӓ", "codepoints": ["U+04D3"]},
    {"ipa": "ə ʌ ɜ", "graphemes": "ъ", "context": "word-final unstressed schwa keeps the source vowel letter (Гӧ̄те, бабушка)"},
    {"ipa": "a ɑ", "graphemes": "а"},
    {"ipa": "ɨ", "graphemes": "ы", "note": "Korean ɯ → ы; Japanese ɯ → у by declared convention"},
    {"ipa": "y ʏ", "graphemes": "ӱ", "codepoints": ["U+04F1"]},
    {"ipa": "ø œ", "graphemes": "ӧ", "codepoints": ["U+04E7"]},
    {"ipa": "ɔ̃ õ", "graphemes": "ѫ", "codepoints": ["U+046B"]},
    {"ipa": "ɛ̃", "graphemes": "ѧ", "codepoints": ["U+0467"]},
    {"ipa": "jɛ̃", "graphemes": "ьѧ", "note": "font fuses to ѩ; precomposed U+0469 accepted"},
    {"ipa": "jɔ̃", "graphemes": "ьѫ", "note": "font fuses to ѭ; precomposed U+046D accepted"},
    {"ipa": "ɑ̃ ɐ̃", "graphemes": "а̨", "codepoints": ["U+0430", "U+0328"]},
    {"ipa": "œ̃", "graphemes": "ӧ̨", "codepoints": ["U+04E7", "U+0328"]},
    {"ipa": "Vː", "graphemes": "V+U+0304", "note": "precomposed ӣ U+04E3, ӯ U+04EF"}
  ],
  "prosody": {
    "stress": "U+0300 grave on the stressed vowel (dictionary layer)",
    "mandarin_tones": {"1": "unmarked", "2": "U+0301", "3": "U+030C", "4": "U+0300"},
    "note": "prosody is a dictionary layer, not orthographic; under stacking conflict length drops first"
  }
}
